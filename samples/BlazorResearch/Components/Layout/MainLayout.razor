@inherits LayoutComponentBase

<div class="page">
    <header class="site-header">
        <div class="header-inner">
            <div class="brand">
                <span class="brand-icon">🔬</span>
                <span class="brand-name">Strands Research Portal</span>
                <span class="brand-badge">.NET SDK</span>
            </div>
            <p class="brand-tagline">Multi-agent parallel research powered by Amazon Bedrock</p>
        </div>
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="site-footer">
        Strands .NET SDK · Blazor Server · Amazon Bedrock ·
        <a href="https://github.com/apncodes/strands.net" target="_blank" rel="noreferrer">GitHub</a>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred. <a href="." class="reload">Reload</a>
</div>
